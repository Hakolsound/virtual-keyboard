{
  "manifest_version": 3,
  "name": "Virtual Keyboard",
  "version": "1.0.0",
  "description": "Touch-optimised virtual keyboard for kiosk Chrome sessions",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://accounts.google.com/*",
        "*://login.microsoftonline.com/*",
        "*://login.live.com/*",
        "*://appleid.apple.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
